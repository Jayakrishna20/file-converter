# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the config line if you want to commit your vendor folder)
vendor/

# Go workspace file
go.work
go.work.sum

# Standard IDE and OS ignores (optional but recommended)
.idea/
.vscode/
.DS_Store

# Output directories
output/
